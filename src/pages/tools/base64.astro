---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ToolPageStyles from '../../components/tools/ToolPageStyles.astro';
import ToolTabsScript from '../../components/tools/ToolTabsScript.astro';
---

<ToolLayout title="Base64 编解码" description="支持文本编解码、图片转 Base64、Base64 转图片预览与下载。">
  <div class="tool-switch mb-4">
    <button class="tool-tab active" type="button" data-tab="text">文本</button>
    <button class="tool-tab" type="button" data-tab="image">图片</button>
  </div>

  <ToolTabsScript />

  <section class="tool-panel" data-panel="text">
    <div class="card border-0 shadow-sm mb-4 tool-card">
      <div class="card-body p-4 p-md-4">
        <label class="font-weight-bold mb-2 d-block tool-label">输入内容</label>
        <textarea id="base64-input" class="form-control tool-textarea mb-3" rows="8" placeholder="请输入要编码或解码的文本内容"></textarea>
        <div class="d-flex flex-wrap gap-2 mb-3 tool-actions">
          <button id="base64-encode" class="btn btn-primary" type="button">文本转 Base64</button>
          <button id="base64-decode" class="btn btn-outline-primary" type="button">Base64 转文本</button>
          <button id="base64-clear" class="btn btn-outline-secondary" type="button">清空文本区</button>
          <button id="base64-copy" class="btn btn-outline-dark" type="button">复制结果</button>
        </div>
        <label class="font-weight-bold mb-2 d-block tool-label">输出结果</label>
        <textarea id="base64-output" class="form-control tool-textarea" rows="8" placeholder="结果会显示在这里"></textarea>
      </div>
    </div>
  </section>

  <section class="tool-panel d-none" data-panel="image">
    <div class="card border-0 shadow-sm mb-4 tool-card">
      <div class="card-body p-4 p-md-4">
        <div class="d-flex flex-wrap align-items-center justify-content-between mb-3 gap-3">
          <div>
            <div class="font-weight-bold tool-label mb-1">上传图片转 Base64</div>
            <div id="image-file-meta" class="text-muted small mt-1"></div>
          </div>
          <label class="btn btn-primary mb-0 tool-upload-btn">
            <span>选择图片</span>
            <input id="image-file-input" type="file" accept="image/*" hidden>
          </label>
        </div>

        <div class="row">
          <div class="col-lg-6 mb-4">
            <label class="font-weight-bold mb-2 d-block tool-label">原图预览</label>
            <div class="tool-preview-box">
              <img id="source-image-preview" class="tool-preview-image d-none" alt="上传图片预览">
              <div id="source-image-empty" class="tool-preview-empty">选择图片后会在这里显示原图预览</div>
            </div>
            <div class="d-flex flex-wrap gap-2 mt-3 tool-actions">
              <button id="image-to-base64-copy" class="btn btn-outline-dark" type="button">复制图片 Base64</button>
              <button id="image-to-base64-clear" class="btn btn-outline-secondary" type="button">清空图片结果</button>
            </div>
          </div>

          <div class="col-lg-6 mb-4">
            <label class="font-weight-bold mb-2 d-block tool-label">图片 Base64 结果</label>
            <textarea id="image-base64-output" class="form-control tool-textarea" rows="12" placeholder="选择图片后会自动生成 Data URL / Base64"></textarea>
          </div>
        </div>

        <div class="row">
          <div class="col-lg-6 mb-4 mb-lg-0">
            <label class="font-weight-bold mb-2 d-block tool-label">Base64 转图片</label>
            <textarea id="base64-image-input" class="form-control tool-textarea" rows="12" placeholder="请输入图片的 Base64 或 Data URL，例如 data:image/png;base64,..."></textarea>
            <div class="d-flex flex-wrap gap-2 mt-3 tool-actions">
              <button id="base64-to-image-preview-btn" class="btn btn-primary" type="button">生成图片预览</button>
              <button id="base64-image-clear" class="btn btn-outline-secondary" type="button">清空预览区</button>
            </div>
          </div>

          <div class="col-lg-6">
            <label class="font-weight-bold mb-2 d-block tool-label">图片预览</label>
            <div class="tool-preview-box">
              <img id="base64-image-preview" class="tool-preview-image d-none" alt="Base64 图片预览">
              <div id="image-preview-empty" class="tool-preview-empty">输入图片 Base64 后可在这里预览</div>
            </div>
            <div class="d-flex flex-wrap gap-2 mt-3 tool-actions">
              <a id="base64-image-download" class="btn btn-outline-primary disabled" download="base64-image.png" href="javascript:">下载图片</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <p id="base64-status" class="tool-status text-muted mb-0"></p>

  <script is:inline>
    (function () {
      var tabs = Array.prototype.slice.call(document.querySelectorAll('.tool-tab'));
      var panels = Array.prototype.slice.call(document.querySelectorAll('.tool-panel'));
      var status = document.getElementById('base64-status');

      var input = document.getElementById('base64-input');
      var output = document.getElementById('base64-output');
      var encodeBtn = document.getElementById('base64-encode');
      var decodeBtn = document.getElementById('base64-decode');
      var clearBtn = document.getElementById('base64-clear');
      var copyBtn = document.getElementById('base64-copy');

      var imageFileInput = document.getElementById('image-file-input');
      var imageFileMeta = document.getElementById('image-file-meta');
      var imageBase64Output = document.getElementById('image-base64-output');
      var imageToBase64CopyBtn = document.getElementById('image-to-base64-copy');
      var imageToBase64ClearBtn = document.getElementById('image-to-base64-clear');
      var sourceImagePreview = document.getElementById('source-image-preview');
      var sourceImageEmpty = document.getElementById('source-image-empty');

      var base64ImageInput = document.getElementById('base64-image-input');
      var previewBtn = document.getElementById('base64-to-image-preview-btn');
      var previewImg = document.getElementById('base64-image-preview');
      var previewEmpty = document.getElementById('image-preview-empty');
      var previewClearBtn = document.getElementById('base64-image-clear');
      var downloadLink = document.getElementById('base64-image-download');

      if (sourceImagePreview) {
        sourceImagePreview.addEventListener('error', function () {
          resetSourcePreview();
          setStatus('图片预览加载失败，请重新选择图片', true);
        });
      }

      if (previewImg) {
        previewImg.addEventListener('error', function () {
          resetPreview();
          setStatus('图片解析失败，请确认 Base64 是否正确', true);
        });
      }

      function setStatus(text, isError) {
        if (!status) return;
        status.textContent = text || '';
        status.classList.toggle('text-danger', !!isError);
        status.classList.toggle('text-muted', !isError);
      }

      function encodeUtf8(str) {
        return btoa(unescape(encodeURIComponent(str)));
      }

      function decodeUtf8(str) {
        return decodeURIComponent(escape(atob(str)));
      }

      function normalizeImageDataUrl(value) {
        var raw = String(value || '').trim();
        if (!raw) return '';
        if (/^data:image\/[a-zA-Z0-9.+-]+;base64,/.test(raw)) return raw;
        return 'data:image/png;base64,' + raw.replace(/^base64,?/i, '').replace(/\s+/g, '');
      }

      function resetSourcePreview() {
        if (sourceImagePreview) {
          sourceImagePreview.removeAttribute('src');
          sourceImagePreview.classList.add('d-none');
        }
        if (sourceImageEmpty) sourceImageEmpty.style.display = 'flex';
        if (imageFileMeta) imageFileMeta.textContent = '';
      }

      function resetPreview() {
        if (previewImg) {
          previewImg.removeAttribute('src');
          previewImg.classList.add('d-none');
        }
        if (previewEmpty) previewEmpty.style.display = 'flex';
        if (downloadLink) {
          downloadLink.setAttribute('href', 'javascript:');
          downloadLink.classList.add('disabled');
        }
      }

      async function copyText(value, successText) {
        if (!value) {
          setStatus('当前没有可复制的内容', true);
          return;
        }
        try {
          await navigator.clipboard.writeText(value);
          setStatus(successText, false);
        } catch (e) {
          setStatus('复制失败，请手动复制', true);
        }
      }

      encodeBtn && encodeBtn.addEventListener('click', function () {
        try {
          output.value = encodeUtf8(input.value || '');
          setStatus('文本已编码为 Base64', false);
        } catch (e) {
          setStatus('编码失败，请检查输入内容', true);
        }
      });

      decodeBtn && decodeBtn.addEventListener('click', function () {
        try {
          output.value = decodeUtf8(input.value || '');
          setStatus('Base64 已解码为文本', false);
        } catch (e) {
          setStatus('解码失败，输入内容不是合法的 Base64', true);
        }
      });

      clearBtn && clearBtn.addEventListener('click', function () {
        input.value = '';
        output.value = '';
        setStatus('文本内容已清空', false);
      });

      copyBtn && copyBtn.addEventListener('click', function () {
        copyText(output.value || '', '结果已复制到剪贴板');
      });

      imageFileInput && imageFileInput.addEventListener('change', function () {
        var file = imageFileInput.files && imageFileInput.files[0];
        if (!file) return;
        var reader = new FileReader();
        reader.onload = function () {
          var result = String(reader.result || '');
          if (imageBase64Output) imageBase64Output.value = result;
          if (sourceImagePreview) {
            sourceImagePreview.src = result;
            sourceImagePreview.classList.remove('d-none');
          }
          if (sourceImageEmpty) sourceImageEmpty.style.display = 'none';
          if (imageFileMeta) {
            var sizeText = file.size >= 1024 * 1024
              ? (file.size / (1024 * 1024)).toFixed(2) + ' MB'
              : Math.max(1, Math.round(file.size / 1024)) + ' KB';
            imageFileMeta.textContent = file.name + ' · ' + sizeText;
          }
          setStatus('图片已转换为 Base64', false);
        };
        reader.onerror = function () {
          setStatus('图片读取失败，请重试', true);
        };
        reader.readAsDataURL(file);
      });

      imageToBase64CopyBtn && imageToBase64CopyBtn.addEventListener('click', function () {
        copyText((imageBase64Output && imageBase64Output.value) || '', '图片 Base64 已复制到剪贴板');
      });

      imageToBase64ClearBtn && imageToBase64ClearBtn.addEventListener('click', function () {
        if (imageBase64Output) imageBase64Output.value = '';
        if (imageFileInput) imageFileInput.value = '';
        resetSourcePreview();
        setStatus('图片结果已清空', false);
      });

      previewBtn && previewBtn.addEventListener('click', function () {
        try {
          var dataUrl = normalizeImageDataUrl((base64ImageInput && base64ImageInput.value) || '');
          if (!dataUrl) {
            resetPreview();
            setStatus('请先输入图片 Base64', true);
            return;
          }
          if (previewImg) {
            previewImg.src = dataUrl;
            previewImg.classList.remove('d-none');
          }
          if (previewEmpty) previewEmpty.style.display = 'none';
          if (downloadLink) {
            downloadLink.setAttribute('href', dataUrl);
            downloadLink.classList.remove('disabled');
          }
          setStatus('图片预览已生成', false);
        } catch (e) {
          resetPreview();
          setStatus('图片解析失败，请确认 Base64 是否正确', true);
        }
      });

      previewClearBtn && previewClearBtn.addEventListener('click', function () {
        if (base64ImageInput) base64ImageInput.value = '';
        resetPreview();
        setStatus('图片预览已清空', false);
      });

      resetSourcePreview();
      resetPreview();
    })();
  </script>

  <ToolPageStyles />
</ToolLayout>
